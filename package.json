{
  "name": "roams-saas",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "description": "Simulador y presupuestador de suscripciones SaaS multi-divisa (herramienta interna comercial)",
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p tsconfig.e2e.json",
    "seed": "npm run seed -w backend"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0"
  }
}
