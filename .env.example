# Variables de entorno del backend (todas opcionales: los defaults sirven para evaluar).
# Este fichero documenta; los valores reales van en un .env que NO se versiona.

# Puerto de la API (default: 3000).
#PORT=3000

# Ruta del fichero SQLite (default: backend/roams.db; se crea y siembra solo).
# Los E2E usan :memory: para arrancar cada ejecución con el seed limpio.
#DB_PATH=backend/roams.db

# URL del proveedor de tipos de cambio (default: open.er-api.com). Existe para que los
# E2E apunten a un fixture local; sigue siendo configuración de servidor, nunca entrada
# de usuario (sin superficie SSRF).
#RATES_URL=https://open.er-api.com/v6/latest/EUR

# Ponlo a 1 SOLO detrás de un proxy de confianza (TLS terminator): hace que el rate
# limit del login se llavee por la IP real (X-Forwarded-For) y no por la del proxy.
# Sin proxy delante, esa cabecera la escribe cualquiera: jamás por defecto.
#TRUST_PROXY=0
